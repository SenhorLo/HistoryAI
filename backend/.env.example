# Copie para .env e preencha. NUNCA commite o .env real.

# Postgres — local em dev; em produção use a connection string do Neon/Supabase
DATABASE_URL="postgresql://usuario:senha@localhost:5432/historyai"

# Provedor de IA: "gemini" (gratuito) ou "claude"
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=

# Segredo que assina os tokens de sessão (JWT).
# Gere um valor longo e aleatório, ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=3001

# Rate limiting (opcional — têm padrões seguros embutidos)
# Chat: mensagens por usuário por janela (protege a cota da IA)
CHAT_RATE_MAX=20
CHAT_RATE_WINDOW_MIN=5
# Auth: tentativas de login/registro por IP por janela (anti força bruta)
AUTH_RATE_MAX=10
AUTH_RATE_WINDOW_MIN=15

# Só necessário se o frontend for hospedado em domínio separado do backend.
# Aceita múltiplas origens separadas por vírgula.
# CORS_ORIGIN=https://historyai.vercel.app
